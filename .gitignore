# ==========================================
# 1. 依赖目录 (绝对禁止上传)
# ==========================================
node_modules/

# ==========================================
# 2. 构建产物 (由 npm run build 生成)
# ==========================================
dist/
dist-ssr/

# ==========================================
# 3. 编辑器与 IDE 配置
# ==========================================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# 4. 操作系统垃圾文件
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# 5. 日志与临时文件
# ==========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# 6. 你的项目中特有的忽略项
# ==========================================
# Figma 相关缓存
.figma/

# TypeScript 增量编译缓存 (下次编译会自动生成)
*.tsbuildinfo

# 环境变量文件 (如果有敏感信息，务必忽略)
.env
.env.local
.env.*.local
docs/ai-chat/20260602-homepage-redesign.md
